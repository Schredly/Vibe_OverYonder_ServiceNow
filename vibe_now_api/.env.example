# Vibe OverYonder API — environment
PORT=5275

# 32-byte hex master key used to encrypt stored passwords. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
VIBE_MASTER_KEY=change-me-to-a-real-32-byte-hex-string

# Workspace + DB locations (relative paths resolve against the repo root)
VIBE_DB_PATH=./data/vibe.db
VIBE_WORKSPACES_DIR=./workspaces

# Dev-only CORS origin. Defaults to http://localhost:5174.
VIBE_WEB_ORIGIN=http://localhost:5174

# The PDI company prefix. Used to auto-prefix scopes at generation time.
# dev378814 PDI uses x_1939459_
VIBE_SCOPE_PREFIX=x_1939459_
